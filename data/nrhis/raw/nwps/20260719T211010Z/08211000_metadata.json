    "impacts": [
      {
        "stage": 48.7,
        "statement": "Flood of record - Septemeber 24, 1967 - remnants of Hurricane Beulah (138,000 cfs)."
      },
      {
        "stage": 43.5,
        "statement": "Massive life threatening flooding occurs, and severely damages residential areas below Bluntzer to Calallen. Major flooding of the flood plain below Lake Corpus Christi to below Bluntzer, floods roads and bridges near the river. Livestock are cut off and potentially drowned. Just below the dam, water is over the Highway 359 bridge around the right end."
      },
      {
        "stage": 29.34,
        "statement": "Major lowland flooding occurs, causing widespread evacuations downstream above Calallen. The west bank residents below Bluntzer may be cut off for several weeks."
      },
      {
        "stage": 28,
        "statement": "Major lowland flooding occurs, causing widespread evacuations downstream above Calallen. The west bank residents below Bluntzer may be cut off for 4 to 6 weeks."
      },
      {
        "stage": 27,
        "statement": "Flow moves into a secondary channel, 700 feet left of main channel, resulting in two channels. These channels merge at 43.5 feet."
      },
      {
        "stage": 26,
        "statement": "Moderate lowland flooding occurs. Many homes downstream between Bluntzer and Calallan become flooded, with residents possibly cut off for weeks."
      },
      {
        "stage": 25,
        "statement": "Minor lowland flooding occurs. Flow escapes secondary banks of the main channel. There is widespread flooding of the flood plain downstream, between Bluntzer and Calallen, cutting off many homes and residential areas for days and possibly weeks."
      },
      {
        "stage": 20,
        "statement": "Overbank conditions continue. Residents downstream near Bluntzer may become isolated."
      },
      {
        "stage": 17,
        "statement": "Many homes in flood prone areas downstream above Calallen are cut off and surrounded by water."
      },
      {
        "stage": 16,
